{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "clean": "rm -rf packages/*/dist",
    "docs": "npx typedoc",
    "test": "npm run build && npx tsx test/sdk.ts && npx tsx test/agents.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "smoke": "npx tsx examples/shared/tui-ink/__bus-smoke.ts && npx tsx examples/shared/tui-ink/__reducer-smoke.ts && npx tsx examples/shared/tui-ink/__config-smoke.ts && npx tsx examples/deep-research/__download-smoke.ts && npx tsx examples/compare/tui/__reducer-smoke.ts",
    "smoke:visual": "npx tsx examples/shared/tui-ink/__visual-smoke.tsx",
    "examples:deep-research": "npx tsx examples/deep-research/main.ts",
    "examples:compare": "npx tsx examples/compare/main.ts",
    "examples:react": "npx tsx examples/react-agent/main.ts",
    "examples:reflect": "npx tsx examples/reflection/main.ts"
  },
  "devDependencies": {
    "@lloyal-labs/lloyal.node": "^2.1.0",
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.28",
    "fast-check": "^4.7.0",
    "ink": "^4.4.1",
    "react": "^18.3.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.0",
    "typedoc-rhineai-theme": "^1.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "version": "1.1.0"
}
